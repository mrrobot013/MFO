# =====================================================================
# Конфигурация парсера МФО (скопируй в .env)
# =====================================================================

TRACKER_URL=https://t.leads.tech/click/8/330/?sub1=bizdev&sub2=Name_vacancy

# SMS: webhook (iPhone Forward SMS авто) | manual (ввод в интерфейсе/терминале) | onlinesim
SMS_PROVIDER=webhook
SMS_LISTEN_MINUTES=15
SMS_POLL_INTERVAL=5

ONLINESIM_API_KEY=

# iPhone Forward SMS webhook: приложение на телефоне отправляет SMS/звонки на Mac
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8765
WEBHOOK_TOKEN=
WEBHOOK_PHONE=

# Ручной режим: номер вводится в интерфейсе или в консоли при python main.py run
MANUAL_DEFAULT_SENDER=web-zaim.ru

# Звонки: webhook | off | zadarma | mock (mock только для demo --with-calls)
CALL_PROVIDER=webhook
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_VIRTUAL_NUMBER=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LOAN_AMOUNT=15000
LOAN_TERM_DAYS=14
FAKE_EMAIL_DOMAIN=mail.ru

# cdp = attach к Chrome :9222 (рекомендуется для web-zaim.ru)
BROWSER_MODE=cdp
CDP_ENDPOINT=http://127.0.0.1:9222
HEADLESS=false
USER_AGENT=
KEEP_BROWSER_OPEN=false
CLOSE_BROWSER_AFTER_SUBMIT=true

OUTPUT_DIR=./data
DB_PATH=./data/sms_log.db
XLSX_PATH=./data/sms_log.xlsx
CSV_PATH=./data/sms_log.csv

LOG_LEVEL=INFO
PARSER_TIMEZONE=Europe/Moscow
